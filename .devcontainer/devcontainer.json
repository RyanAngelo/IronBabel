{
    "name": "IronBabel Development",
    "dockerFile": "Dockerfile",
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "serayuzgur.crates",
                "tamasfe.even-better-toml",
                "vadimcn.vscode-lldb",
                "ms-vscode.vscode-typescript-next"
            ],
            "settings": {
                "rust-analyzer.checkOnSave.command": "clippy"
            }
        }
    },
    "forwardPorts": [],
    "postCreateCommand": "cargo build",
    "remoteUser": "vscode"
} 